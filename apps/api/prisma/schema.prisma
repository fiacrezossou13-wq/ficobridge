generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  twoFASecret   String?
  twoFAEnabled  Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  applications  Application[]
  documents     Document[]
  activities    ActivityLog[]
  notifications Notification[]
  calendarEvents CalendarEvent[]

  @@map("users")
}

model Application {
  id                String            @id @default(uuid())
  userId            String
  company           String
  position          String
  city              String
  sector            String
  contractType      ContractType
  salary            String?
  platform          String
  offerUrl          String?
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  cvSent            Boolean           @default(false)
  coverLetter       Boolean           @default(false)
  portfolioUrl      String?
  notes             String?
  status            ApplicationStatus   @default(SENT)
  sentAt            DateTime          @default(now())
  followUpAt        DateTime?
  interviewAt       DateTime?
  responseAt        DateTime?
  aiScore           Int?
  aiCompatibility   Float?
  aiSuggestions     String?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         Document[]
  history           ApplicationHistory[]

  @@index([userId])
  @@index([status])
  @@map("applications")
}

model ApplicationHistory {
  id            String    @id @default(uuid())
  applicationId String
  action        String
  details       String?
  createdAt     DateTime  @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_history")
}

model Document {
  id            String    @id @default(uuid())
  userId        String
  applicationId String?
  name          String
  type          DocumentType
  url           String
  size          Int
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id])

  @@map("documents")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  ip        String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Notification {
  id        String            @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean           @default(false)
  actionUrl String?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  location    String?
  type        EventType
  googleId    String?
  outlookId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startAt])
  @@map("calendar_events")
}

enum Role {
  USER
  ADMIN
}

enum ContractType {
  ALTERNANCE
  STAGE
  CDD
  CDI
  FREELANCE
}

enum ApplicationStatus {
  SENT
  FOLLOWUP
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  GHOSTED
  WITHDRAWN
}

enum DocumentType {
  CV
  COVER_LETTER
  PORTFOLIO
  CERTIFICATE
  OTHER
}

enum NotificationType {
  REMINDER
  INTERVIEW
  OFFER
  SYSTEM
  AI_SUGGESTION
}

enum EventType {
  INTERVIEW
  FOLLOWUP
  DEADLINE
  PERSONAL
}
